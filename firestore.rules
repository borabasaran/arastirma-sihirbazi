rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdvisor() {
      return signedIn()
        && request.auth.token.email in
           get(/databases/$(database)/documents/config/app).data.advisorEmails;
    }

    function isApproved() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // Uygulama yapılandırması (seçenek listeleri + danışman e-postaları)
    match /config/app {
      allow read: if signedIn();
      allow write: if isAdvisor();
    }

    // Kullanıcı profilleri
    match /users/{uid} {
      // Öğrenci kendi profilini yalnızca "pending" durumuyla oluşturabilir
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.status == 'pending';
      allow read: if signedIn() && (request.auth.uid == uid || isAdvisor());
      // Öğrenci kendi profilini güncelleyebilir ama status alanını değiştiremez
      allow update: if isAdvisor()
        || (signedIn() && request.auth.uid == uid
            && request.resource.data.status == resource.data.status);
      allow delete: if isAdvisor();
    }

    // Sihirbaz verileri (öğrenci başına tek belge)
    match /submissions/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdvisor());
      allow create, update: if (signedIn() && request.auth.uid == uid && isApproved())
        || isAdvisor();
      allow delete: if isAdvisor();
    }
  }
}
