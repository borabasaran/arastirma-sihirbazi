rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basitleştirilmiş kurallar: okuma serbest, yazma giriş yapmış kullanıcıya açık.
    // (Panel ve sihirbaz sorunsuz çalışsın diye sadeleştirildi.)
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
